{
  "name": "venuespeed",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:admin": "npm run dev --workspace=apps/admin",
    "dev:realtime": "npm run dev --workspace=apps/realtime",
    "build:all": "npm run build --workspaces"
  }
}